{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "gomod": {
    "managerFilePatterns": ["/(^|/)go\\.mod$/", "/(^|/)golangci-lint\\.mod$/", "/(^|/)gotestsum\\.mod$/"]
  },
  "packageRules": [
    {
      "matchFileNames": ["go.mod"],
      "postUpdateOptions": ["gomodTidy"]
    },
    {
      "matchManagers": ["gomod"],
      "matchFileNames": ["!go.mod"],
      "goGetDirs": ["."]
    },
    {
      "matchFileNames": ["golangci-lint.mod"],
      "postUpgradeTasks": {
        "commands": [
          "rm -f golangci-lint.sum",
          "go get -modfile=golangci-lint.mod -tool github.com/golangci/golangci-lint/v2/cmd/golangci-lint",
          "go tool -modfile=golangci-lint.mod golangci-lint run ./... --fix"
        ],
        "executionMode": "branch"
      }
    },
    {
      "matchFileNames": ["gotestsum.mod"],
      "postUpgradeTasks": {
        "commands": ["rm -f gotestsum.sum", "go get -modfile=gotestsum.mod -tool gotest.tools/gotestsum"],
        "executionMode": "branch"
      }
    },
    {
      "matchFileNames": ["go.mod"],
      "postUpgradeTasks": {
        "commands": [
          "go mod download",
          "go generate ./...",
          "go mod download -modfile=golangci-lint.mod",
          "go tool -modfile=golangci-lint.mod golangci-lint run ./... --fix"
        ],
        "executionMode": "branch"
      }
    },
    {
      "matchManagers": ["npm"],
      "postUpdateOptions": ["pnpmDedupe"],
      "postUpgradeTasks": {
        "commands": ["pnpm format"],
        "executionMode": "branch"
      }
    }
  ],
  "extends": ["config:recommended"]
}
